{
  "name": "sysmlv2-ls-service",
  "version": "0.1.0",
  "private": true,
  "description": "Docker-ready SysML v2 validation microservice built on the sysml-2ls language server core.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build:upstream": "pnpm --dir upstream/sysml-2ls/packages/syside-languageserver run grammar:generate && pnpm --filter syside-base --filter syside-protocol --filter syside-languageserver run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,js,mjs}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,json,yml,yaml}\" \"docs/**/*.md\" \"openapi/**/*.yaml\" \"codecov.yml\" \"pnpm-workspace.yaml\" \".github/workflows/*.yml\" \".readthedocs.yaml\" \"mkdocs.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,mjs}\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,json,yml,yaml}\" \"docs/**/*.md\" \"openapi/**/*.yaml\" \"codecov.yml\" \"pnpm-workspace.yaml\" \".github/workflows/*.yml\" \".readthedocs.yaml\" \"mkdocs.yml\"",
    "lint": "eslint .",
    "docs:check": "pnpm run docs:check:full",
    "smoke:start": "node scripts/smoke-start.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "pnpm audit --audit-level moderate",
    "version:check": "node scripts/check-version.mjs",
    "ci": "pnpm run version:check && pnpm run format:check && pnpm run typecheck && pnpm run lint && pnpm run comments:check && pnpm run test:coverage && pnpm run build && pnpm run smoke:start",
    "comments:check": "node scripts/check-jsdoc.mjs",
    "openapi:lint": "redocly lint openapi/service.v1.yaml",
    "openapi:check": "pnpm run openapi:lint && vitest run tests/openapi-contract.test.ts",
    "docs:generate:version": "node scripts/docs/generate-version-stamp.mjs",
    "docs:generate:cli": "node scripts/docs/generate-cli-docs.mjs",
    "docs:generate:openapi": "node scripts/docs/generate-openapi-docs.mjs",
    "docs:generate:typedoc": "node scripts/docs/generate-typedoc.mjs",
    "docs:generate:base": "pnpm run docs:generate:version && pnpm run docs:generate:cli && pnpm run docs:generate:openapi && pnpm run docs:generate:typedoc",
    "docs:generate:upstream": "node scripts/docs/inventory-upstream.mjs",
    "docs:generate:full": "pnpm run docs:generate:base && pnpm run docs:generate:upstream",
    "docs:build": "mkdocs build --strict",
    "docs:generated:check:base": "node scripts/docs/check-generated-docs.mjs --scope base",
    "docs:generated:check:full": "node scripts/docs/check-generated-docs.mjs --scope full",
    "docs:secrets:check": "node scripts/docs/check-secrets.mjs",
    "docs:check:base": "pnpm run openapi:check && pnpm run docs:generate:base && pnpm run docs:generated:check:base && pnpm run docs:secrets:check && pnpm run docs:build",
    "docs:check:full": "pnpm run openapi:check && pnpm run docs:generate:full && pnpm run docs:generated:check:full && pnpm run docs:secrets:check && pnpm run docs:build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.2.0",
    "langium": "~1.2.0",
    "syside-base": "workspace:*",
    "syside-languageserver": "workspace:*",
    "syside-protocol": "workspace:*",
    "vscode-languageserver": "~8.0.2",
    "vscode-uri": "3.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/expect-utils": "^30.4.1",
    "@jest/globals": "^30.4.1",
    "@redocly/cli": "^2.37.0",
    "@types/node": "^20.19.0",
    "@vitest/coverage-v8": "4.1.9",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "expect": "^30.4.1",
    "jest-matcher-utils": "^30.4.1",
    "jest-snapshot": "^30.4.1",
    "prettier": "^3.6.2",
    "shx": "^0.4.0",
    "tsx": "^4.23.0",
    "typedoc": "0.25.13",
    "typedoc-plugin-markdown": "3.17.1",
    "typescript": "5.1.3",
    "typescript-eslint": "^8.18.2",
    "vite": "8.1.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1"
    }
  }
}
